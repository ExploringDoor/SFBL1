# Staging environment template. Copy to `.env.staging` (also gitignored)
# and fill in real values from the staging Firebase project.
#
# Staging is a separate Firebase project that mirrors prod. Rules deploy
# here first as a smoke test before being promoted to prod. See PLAN.md
# §"Deployment Lifecycle" for the rules promotion checklist.

# Public values (these ride along into the client bundle).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=leagueengine-staging.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=leagueengine-staging
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=leagueengine-staging.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false

LEAGUEENGINE_APEX_DOMAINS=staging.leagueengine.com,localhost

# Server-only.
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/staging-service-account.json
