rules_version = '2';

// Per-tenant security rules. Custom claims live at
// `request.auth.token.leagues[leagueId]`, where the value is one of:
//   - "admin"               → full league control
//   - "captain:<team_id>"   → write own team's box scores + lineups
//   - "player:<player_id>"  → read-only auxiliary identity (no extra perms)
//
// Public-facing collections (teams/games/standings/etc.) are public-read
// because the league site is a public website. Writes are claims-gated.
// Sensitive collections (audit, billing_history) are member-read or denied.

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------------
    // Helpers
    // ---------------------------------------------------------------------

    function leagueRole(leagueId) {
      return request.auth == null
        ? null
        : request.auth.token.get('leagues', {}).get(leagueId, null);
    }

    function isAdmin(leagueId) {
      return leagueRole(leagueId) == 'admin';
    }

    // Anchored, single-segment team id: "captain:team_a" — yes;
    // "captain:foo:bar" or "captain:" — no.
    function captainTeamId(leagueId) {
      let role = leagueRole(leagueId);
      return role != null && role is string && role.matches('^captain:[^:]+$')
        ? role.split(':')[1]
        : null;
    }

    // Audit L20 (perf, accepted): the get() below is a billed read on
    // every box-score / lineup write (~600 extra reads on a 20-captain
    // Saturday). Required — rules can't otherwise know the game's
    // teams — and negligible at current scale. Track if Firestore
    // read cost ever surprises; there's no cheaper correct option in
    // rules (denormalizing team ids onto the write doc would let a
    // caller spoof them).
    function isCaptainOfGameTeam(leagueId, gameId) {
      let teamId = captainTeamId(leagueId);
      let game = get(/databases/$(database)/documents/leagues/$(leagueId)/games/$(gameId)).data;
      return teamId != null
        && (teamId == game.home_team_id || teamId == game.away_team_id);
    }

    // Doc id format for lineups + box_score_submissions:
    //   `${gameId}_${teamId}`
    // Caller must already have asserted the doc id ENDS with the
    // captain's `_<teamId>`. We strip that suffix to recover the
    // gameId, then verify the captain is actually in that game via
    // isCaptainOfGameTeam (which reads the game doc).
    //
    // Why this matters: without this check, the lineup/submission
    // rules only verified the doc id ended with the captain's team
    // id — a captain of team_a could then write a lineup for ANY
    // game in their league as long as the doc id was named
    // `<otherGameId>_team_a`. The downstream public box-score is
    // protected separately, but the submission lane itself was
    // poisonable.
    function isCaptainOfDocGame(leagueId, docId) {
      let teamId = captainTeamId(leagueId);
      // Strategy: match `^.+_<teamId>$` to assert the doc id has the
      // expected `${gameId}_${teamId}` shape, THEN split by
      // `_<teamId>` and take the first chunk as the gameId.
      //
      // Firestore Rules doesn't have substring/range — only split(),
      // matches(), replace() (verified empirically: substring + range
      // both throw "Function not found"). split() returns a list and
      // we already use it in captainTeamId. Edge case to be aware of:
      // if a gameId ITSELF contains `_<teamId>` (e.g. team_id="a" and
      // game_id="x_team_a_y"), split returns multiple chunks and we
      // pick the wrong gameId; isCaptainOfGameTeam then fails on a
      // missing game → rule denies, which is safe-but-strict. Real
      // provision-script game ids are `g_YYYY_MM_DD_NNN` with no team
      // names so this collision is theoretical for SFBL.
      return teamId != null
        && docId.matches('^.+_' + teamId + '$')
        && isCaptainOfGameTeam(leagueId, docId.split('_' + teamId)[0]);
    }

    // Player-self check. String equality, not regex — the comparison
    // string is constructed from the trusted playerId path segment, so
    // even if a malformed claim like "player:foo:bar" sneaks in, it
    // won't equal "player:foo".
    function isSelfPlayer(leagueId, playerId) {
      return leagueRole(leagueId) == 'player:' + playerId;
    }

    // ---------------------------------------------------------------------
    // /leagues/{leagueId} — config doc
    //
    // Public-read so middleware (running on Edge with no auth) can resolve
    // tenant config. Admin-write only.
    // ---------------------------------------------------------------------

    match /leagues/{leagueId} {
      allow read: if true;
      allow write: if isAdmin(leagueId);

      // -------------------------------------------------------------------
      // Public-facing collections + their `_private/{doc}` siblings.
      //
      // Convention: anything visible on the public website lives on the
      // parent doc; PII (phone, email, DOB, internal notes) lives in
      // `_private/{doc}`. Never put sensitive fields on parent docs.
      // -------------------------------------------------------------------

      match /teams/{teamId} {
        allow read: if true;
        allow write: if isAdmin(leagueId);

        match /_private/{doc} {
          allow read, write: if isAdmin(leagueId)
                            || captainTeamId(leagueId) == teamId;
        }
      }

      match /games/{gameId} {
        allow read: if true;
        allow write: if isAdmin(leagueId);

        match /_private/{doc} {
          allow read, write: if isAdmin(leagueId);
        }
      }

      match /players/{playerId} {
        allow read: if true;
        allow write: if isAdmin(leagueId);

        match /_private/{doc} {
          allow read, write: if isAdmin(leagueId)
                            || isSelfPlayer(leagueId, playerId);
        }
      }

      match /standings/{divisionId} {
        allow read: if true;
        allow write: if isAdmin(leagueId);
      }

      match /recaps/{gameId} {
        allow read: if true;
        allow write: if isAdmin(leagueId);
      }

      match /page_content/{pageId} {
        allow read: if true;
        allow write: if isAdmin(leagueId);
      }

      // /leagues/{leagueId}/site_config/{docId}
      // Holds homepage banner alerts and other admin-controlled UI
      // bits that need to update faster than the Edge Config cache.
      // Public-read so the homepage (server-rendered) can pick up the
      // current banner immediately. Admin-write only.
      match /site_config/{docId} {
        allow read: if true;
        allow write: if isAdmin(leagueId);
      }

      // /leagues/{leagueId}/photos/{photoId}
      // Photo gallery items. Public-read so the /photos page can list
      // them without auth. Admin writes via /api/admin-photo (which
      // also handles base64 storage size validation).
      match /photos/{photoId} {
        allow read: if true;
        allow write: if isAdmin(leagueId);
      }

      // /leagues/{leagueId}/player_of_week/{entryId}
      // Manually-curated Player of the Week entries. Public-read so
      // the /player-of-the-week page + the admin manager's list can
      // read them without an Admin-SDK round-trip. Admin-only write
      // (mutations go through /api/admin-player-of-week, but the
      // client-write rule mirrors the other public-content
      // collections — photos / page_content / site_config).
      match /player_of_week/{entryId} {
        allow read: if true;
        allow write: if isAdmin(leagueId);
      }

      // Box scores: admin OR captain of one of the teams in the game.
      match /box_scores/{gameId} {
        allow read: if true;
        allow write: if isAdmin(leagueId)
                    || isCaptainOfGameTeam(leagueId, gameId);
      }

      // Lineups: same rule as box scores (captain may set their own team's
      // lineup; admin may set any). Stored under
      // /leagues/{leagueId}/lineups/{gameId}_{teamId}.
      //
      // Regex is anchored so a captain of team_a can't write to
      // `foo_team_a_evil`. Team ids must match [a-z0-9_-]+ at the
      // claim/provisioning layer so regex metachars in the dynamic
      // suffix can't escape.
      //
      // ALSO requires the captain be in the game (via
      // isCaptainOfDocGame → isCaptainOfGameTeam), not just that the
      // doc id ends with their teamId. Without that read of the game
      // doc, a captain could write a lineup for any game in the
      // league as long as the doc id was suffixed with their team id.
      match /lineups/{lineupId} {
        allow read: if true;
        allow write: if isAdmin(leagueId)
                    || isCaptainOfDocGame(leagueId, lineupId);
      }

      // Box score submissions — one per (game, team) pair representing a
      // captain's lane in the 3-lane reconciliation model (PLAN.md §4).
      // Captains write their own team's submission; admin can write/read
      // any. **Reads are NOT public** — captains must not see the
      // opposing captain's submission (otherwise the lane is no longer
      // independent and reconciliation loses its point). The captain
      // can read their own lane (for the editor's pre-fill).
      // Doc id format: `<game_id>_<team_id>`.
      //
      // Same isCaptainOfDocGame check as /lineups above — captain must
      // both own the team suffix AND be in the game.
      match /box_score_submissions/{subId} {
        allow read: if isAdmin(leagueId)
                    || isCaptainOfDocGame(leagueId, subId);
        allow write: if isAdmin(leagueId)
                    || isCaptainOfDocGame(leagueId, subId);
      }

      // Payments — captain tracks who paid season fees. Stored at
      // /leagues/{leagueId}/payments/{playerId}. Writes go through
      // /api/captain-payment (Admin SDK; bypasses rules) so we
      // don't need to widen client-write rules.
      // Reads: admin OR a captain (any captain of this league —
      // payment status is league-level, not super sensitive).
      match /payments/{paymentId} {
        allow read: if isAdmin(leagueId)
                    || captainTeamId(leagueId) != null;
        allow write: if isAdmin(leagueId);
      }

      // -------------------------------------------------------------------
      // /availability/{docId} — game RSVPs
      //
      // Doc id convention: `${team_id}_${game_id}_${player_id}` (matches
      // DVSL captain.html:5341, scoped per-league via this subcollection
      // path so the leagueId prefix is implicit).
      //
      // Doc shape:
      //   { game_id, player_id, player_name, team_id, status, updated_at }
      //
      // Public-read within the tenant (matches DVSL's default; captains
      // and players need to see team-wide RSVP summaries). Writes go
      // through /api/availability-rsvp (Admin SDK) so the server can
      // verify ownership: captain may write for any player on their team,
      // player may write for their own linked player record only.
      // -------------------------------------------------------------------

      match /availability/{docId} {
        allow read: if true;
        allow write: if false;
      }

      // -------------------------------------------------------------------
      // /team_messages/{msgId} — team chat
      //
      // Auth-only read (matches DVSL — chat is team-internal but not
      // privacy-sensitive; restricting to authenticated users blocks
      // anonymous scrapers without making the listener flow more complex).
      // Real-time client SDK reads via onSnapshot() drive the chat tab.
      //
      // No direct client writes — every send/delete/reset goes through
      // /api/chat-message[*] (Admin SDK) so the server can:
      //   - verify caller is captain-of-team or player-on-team
      //   - stamp author_email/author_name/team_color from trusted sources
      //   - fire the team_chat push fan-out as part of the write
      //   - cascade delete to push history (when inbox lands)
      // -------------------------------------------------------------------

      match /team_messages/{msgId} {
        allow read: if request.auth != null;
        allow write: if false;
      }

      // -------------------------------------------------------------------
      // /captain_chat/{msgId} — league-wide captains-only chat
      //
      // Same posture as /team_messages but no team filter — every captain
      // in the league sees these. Naming: `captain_chat` (singular suffix
      // is DVSL convention for the path), but the category string and
      // preference key everywhere else are `captains_chat` (plural).
      // Watch this — DVSL hit a real bug where `category: 'captain_chat'`
      // (singular) silently dropped pushes (notifications spec §4 #4).
      //
      // Reads: authenticated only. The captains-chat reveal in the
      // captain portal is gated client-side by `is_captain_authed` claim,
      // but we keep the rule simple here — anyone authenticated can
      // technically read the messages, and the prefs-UI category opt-in
      // for captains_chat is hidden from non-captains client-side.
      // Tightening this further (e.g. to `captain:` claim only) would
      // mean admins lose read access, which we don't want for moderation.
      // -------------------------------------------------------------------

      match /captain_chat/{msgId} {
        allow read: if request.auth != null;
        allow write: if false;
      }

      // Sensitive: members-only read, admin-only write.
      match /audit/{logId} {
        allow read: if isAdmin(leagueId);
        allow write: if false;
      }

      match /billing_history/{entryId} {
        allow read: if isAdmin(leagueId);
        allow write: if false;
      }
    }

    // ---------------------------------------------------------------------
    // /users/{uid} — own profile only
    // ---------------------------------------------------------------------

    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ---------------------------------------------------------------------
    // /domains/{hostname} — custom domain → leagueId mapping
    //
    // Public-read (middleware needs it pre-auth). Writes go through the
    // provisioning script using server-side credentials, never client SDK.
    // ---------------------------------------------------------------------

    match /domains/{hostname} {
      allow read: if true;
      allow write: if false;
    }

    // ---------------------------------------------------------------------
    // /notification_tokens/{tokenDocId} — FCM push subscription rows
    //
    // Doc id convention: `<fcm_token>_<leagueId>`. Multi-tenant
    // requirement (NOT in DVSL): every doc carries a `leagueId` field
    // and the server-side /api/send-notification filters on it before
    // any other filter runs, so a captain registered for SFBL never
    // receives a push triggered by a KCSL event.
    //
    // Reads are self-only (the user can read their own tokens to
    // populate the prefs UI). Cross-token reads are blocked at the
    // rules level — list/query is denied. The send endpoint runs with
    // Admin SDK and bypasses these rules.
    //
    // Writes from the client are denied entirely. All token mutations
    // (register, prefs change, refresh `authed_teams`/`is_admin`) go
    // through /api/register-notification-token (Admin SDK) so the
    // server can stamp `leagueId` and re-derive trusted fields from
    // the verified ID token + player doc lookup.
    // ---------------------------------------------------------------------

    match /notification_tokens/{tokenDocId} {
      allow read: if request.auth != null
                  && resource.data.auth_uid == request.auth.uid;
      allow write: if false;
    }

    // ---------------------------------------------------------------------
    // /pending_nav/{docId} — in-app notification bell history
    //
    // One doc per (push, recipient device). Written by /api/send-notification
    // after each successful FCM send so the user can see history when they
    // open the site (vs only catching pushes that fired while the OS tray
    // was watching). Read by /api/check-pending-nav for the bell UI; also
    // readable by the doc owner directly so the client can subscribe.
    //
    // Multi-tenant: every doc carries `leagueId`. Cross-tenant push
    // already filtered at the send layer; this is defense-in-depth.
    //
    // Dismissed: client (via /api/dismiss-pending-nav) sets dismissed_at
    // to mark-as-read. Server may delete docs older than ~30 days as
    // a future cleanup pass.
    // ---------------------------------------------------------------------

    match /pending_nav/{docId} {
      allow read: if request.auth != null
                  && resource.data.auth_uid == request.auth.uid;
      allow write: if false;
    }

    // ---------------------------------------------------------------------
    // /errors — append-only platform error log
    //
    // Authenticated-only create so an anonymous attacker can't fill the
    // collection. Phase 2c: replace with a Cloud Function ingest that
    // applies size + rate limits.
    // ---------------------------------------------------------------------

    match /errors/{errorId} {
      allow read: if false;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // ---------------------------------------------------------------------
    // /auth_bridges — short-TTL custom-token handoff for the Safari → PWA
    // sign-in bridge. Each doc holds a Firebase Admin custom token that
    // exchanges for a full session, so a single read by an unauthorized
    // client would let them impersonate any uid mid-bridge. Admin SDK is
    // the ONLY thing meant to read or write here; clients reach the bridge
    // via /api/auth-bridge/* which proxy through the server.
    //
    // Explicit deny instead of relying on the catch-all so a future
    // permissive `{document=**}` rule added during a debugging session
    // can't accidentally expose parked tokens.
    // ---------------------------------------------------------------------

    match /auth_bridges/{bridgeId} {
      allow read, write: if false;
    }

    // Default deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
