# Copy to .env.local and fill in real values once a Firebase project exists.
# All NEXT_PUBLIC_* keys ship to the browser; that is expected for Firebase
# web config (not secret). Server-only secrets (Admin SDK, etc.) come later
# without the NEXT_PUBLIC_ prefix.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Web-Push public key (VAPID) used by the FCM client to subscribe a
# device to push notifications. Get from Firebase Console →
# ⚙ Project settings → Cloud Messaging → "Web Push certificates"
# → "Generate key pair". This is a public value (not a secret); it's
# called NEXT_PUBLIC_* because the browser reads it.
#
# Without this, the /profile#notif "Enable notifications" button shows
# "Push isn't fully configured for this league yet." The prefs UI still
# loads so the user can pre-pick categories.
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Set to "true" to point the client SDK at the local emulator suite.
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false

# Comma-separated list of apex domains that should be split into
# `<slug>.<apex>` for tenant resolution. Anything else is treated as a
# custom domain and looked up in /domains/{hostname}. Defaults to
# "leagueengine.com,localhost" when unset.
LEAGUEENGINE_APEX_DOMAINS=leagueengine.com,localhost

# -----------------------------------------------------------------------
# Server-only credentials (never NEXT_PUBLIC_*)
# -----------------------------------------------------------------------
# Path to a Firebase service account JSON. Required for `npm run seed`
# and any other Admin SDK usage against PROD Firestore. The Admin SDK
# bypasses security rules — that's the point of using it for seeding /
# provisioning / Cloud Functions, but it means leaking this JSON gives
# the holder full read/write across every tenant. Treat like a password.
#
# To generate:
#   Firebase Console → ⚙ Project settings → Service accounts
#   → "Generate new private key" → save under ./secrets/
#
# `secrets/` is in .gitignore. Verify with `git check-ignore -v <path>`.
#
# When running `npm run seed:emulator`, this is NOT required — the script
# auto-detects FIRESTORE_EMULATOR_HOST (set by `firebase emulators:exec`)
# and connects without credentials.
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/service-account.json

# Inline alternative for environments without a local filesystem (Vercel,
# CI, etc.). Set EITHER this OR the path above — admin SDK init reads
# whichever is present. Paste the entire JSON contents on one line:
#
#   FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n…\n-----END PRIVATE KEY-----\n","client_email":"…", ...}'
#
# In Vercel's UI, the env-var value field accepts the multi-line JSON
# directly without quoting. Locally for testing, wrap it in single
# quotes and escape any embedded single quotes.
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Shared secret used by /api/pregame-reminder to authenticate the
# Vercel cron. Vercel cron sends `Authorization: Bearer ${CRON_SECRET}`
# automatically per the platform's contract; the endpoint also accepts
# X-Cron-Secret for manual triggers via curl.
#
# Generate: `openssl rand -hex 32` and store in Vercel project env
# (NOT committed to source). Without this set, the cron endpoint
# fails closed — no anonymous triggers possible.
CRON_SECRET=

# Comma-separated Firebase Auth UIDs of platform administrators.
# These users get to see /_platform — the cross-tenant overview at
# leagueengine.com/_platform. Per-tenant `admin` claim is NOT enough;
# this gates on UID directly.
#
# To find your UID for first-time setup:
#   1. Sign in once at /login on prod
#   2. Firebase Console → Authentication → Users → copy the UID
#   3. Add to Vercel env (NOT committed)
#
# Multi-admin: PLATFORM_ADMIN_UIDS=uid_a,uid_b
# Without this set, /_platform refuses everyone (fail closed).
PLATFORM_ADMIN_UIDS=
