# Copy to .env.local and fill in real values once a Firebase project exists.
# All NEXT_PUBLIC_* keys ship to the browser; that is expected for Firebase
# web config (not secret). Server-only secrets (Admin SDK, etc.) come later
# without the NEXT_PUBLIC_ prefix.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Set to "true" to point the client SDK at the local emulator suite.
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false

# Comma-separated list of apex domains that should be split into
# `<slug>.<apex>` for tenant resolution. Anything else is treated as a
# custom domain and looked up in /domains/{hostname}. Defaults to
# "leagueengine.com,localhost" when unset.
LEAGUEENGINE_APEX_DOMAINS=leagueengine.com,localhost

# -----------------------------------------------------------------------
# Server-only credentials (never NEXT_PUBLIC_*)
# -----------------------------------------------------------------------
# Path to a Firebase service account JSON. Required for `npm run seed`
# and any other Admin SDK usage against PROD Firestore. The Admin SDK
# bypasses security rules — that's the point of using it for seeding /
# provisioning / Cloud Functions, but it means leaking this JSON gives
# the holder full read/write across every tenant. Treat like a password.
#
# To generate:
#   Firebase Console → ⚙ Project settings → Service accounts
#   → "Generate new private key" → save under ./secrets/
#
# `secrets/` is in .gitignore. Verify with `git check-ignore -v <path>`.
#
# When running `npm run seed:emulator`, this is NOT required — the script
# auto-detects FIRESTORE_EMULATOR_HOST (set by `firebase emulators:exec`)
# and connects without credentials.
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/service-account.json
