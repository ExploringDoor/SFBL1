{
  "name": "league-platform",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "emulators": "firebase emulators:start",
    "seed": "tsx scripts/seed.ts",
    "seed:emulator": "firebase emulators:exec --project demo-seed-smoke --only firestore 'tsx scripts/seed.ts'",
    "seed:running": "FIRESTORE_EMULATOR_HOST=localhost:8080 GCLOUD_PROJECT=league-platform-5f3c8 tsx scripts/seed.ts",
    "seed:fixture": "FIRESTORE_EMULATOR_HOST=localhost:8080 GCLOUD_PROJECT=league-platform-5f3c8 tsx scripts/seed-fixture.ts",
    "verify:rules": "FIREBASE_AUTH_EMULATOR_HOST=localhost:9099 FIRESTORE_EMULATOR_HOST=localhost:8080 tsx scripts/verify-rules-editor.ts",
    "grant-claim": "tsx scripts/grant-claim.ts",
    "grant-claim:emulator": "FIREBASE_AUTH_EMULATOR_HOST=localhost:9099 FIRESTORE_EMULATOR_HOST=localhost:8080 tsx scripts/grant-claim.ts",
    "magic-link": "tsx scripts/magic-link.ts",
    "provision": "tsx scripts/provision.ts",
    "provision:emulator": "FIREBASE_AUTH_EMULATOR_HOST=localhost:9099 FIRESTORE_EMULATOR_HOST=localhost:8080 tsx scripts/provision.ts",
    "audit:tenant": "tsx scripts/audit-tenant.ts",
    "audit:tenant:emulator": "FIRESTORE_EMULATOR_HOST=localhost:8080 tsx scripts/audit-tenant.ts",
    "seed:page": "tsx scripts/seed-page-content.ts",
    "seed:page:emulator": "FIRESTORE_EMULATOR_HOST=localhost:8080 tsx scripts/seed-page-content.ts",
    "dump:lbdc": "tsx scripts/dump-lbdc-from-supabase.ts",
    "transform:lbdc": "tsx scripts/transform-lbdc.ts",
    "seed:lbdc": "tsx scripts/seed-lbdc-to-firestore.ts",
    "seed:lbdc:constants": "tsx scripts/seed-lbdc-constants.ts",
    "dev:emulators": "firebase emulators:exec --only auth,firestore,ui 'NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true next dev'",
    "test": "firebase emulators:exec --config firebase.test.json --project demo-test --only auth,firestore 'FIRESTORE_EMULATOR_PORT=8085 FIREBASE_AUTH_EMULATOR_HOST=localhost:9095 vitest run'",
    "test:rules": "firebase emulators:exec --config firebase.test.json --project demo-rules-test --only firestore 'FIRESTORE_EMULATOR_PORT=8085 vitest run tests/rules'",
    "test:auth": "firebase emulators:exec --config firebase.test.json --project demo-auth-claim-test --only auth,firestore 'FIRESTORE_EMULATOR_PORT=8085 FIREBASE_AUTH_EMULATOR_HOST=localhost:9095 vitest run tests/auth'",
    "rules:deploy:staging": "firebase deploy --only firestore:rules --project staging",
    "rules:deploy:prod": "firebase deploy --only firestore:rules --project prod"
  },
  "dependencies": {
    "@tiptap/extension-color": "^3.22.5",
    "@tiptap/extension-image": "^3.22.5",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/extension-text-align": "^3.22.5",
    "@tiptap/extension-text-style": "^3.22.5",
    "@tiptap/extension-underline": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "firebase": "^10.13.0",
    "firebase-admin": "^12.5.0",
    "googleapis": "^171.4.0",
    "isomorphic-dompurify": "^2.16.0",
    "marked": "^14.1.3",
    "next": "14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.4",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.35",
    "firebase-tools": "^13.20.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.7",
    "tsx": "^4.19.0",
    "typescript": "^5.5.3",
    "vitest": "^2.1.0"
  },
  "overrides": {
    "isomorphic-dompurify": {
      "jsdom": "^26.0.0"
    },
    "html-encoding-sniffer": "^4.0.0"
  }
}
